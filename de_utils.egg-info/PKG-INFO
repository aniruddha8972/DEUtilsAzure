## 10. Lineage Tracking

```python
from de_utils import LineageTracker

tracker = LineageTracker(spark, lineage_table="gold._lineage", job_name="daily_orders_etl")

# ── Context manager (auto-captures timing + row counts) ───────────────────────
with tracker.track(source="bronze.orders_raw", target="silver.orders") as rec:
    transformed_df = transform(raw_df)
    transformed_df.write.mode("append").saveAsTable("silver.orders")
    rec.rows_read    = raw_df.count()
    rec.rows_written = transformed_df.count()

# ── Manual record ─────────────────────────────────────────────────────────────
tracker.record(
    source="bronze.raw",
    target="silver.orders",
    transformation_type="INCREMENTAL",
    rows_read=50000,
    rows_written=49800,
    extra_metadata={"watermark": "2024-06-01"},
)
tracker.save()   # flush buffered records to lineage table

# ── Query lineage ─────────────────────────────────────────────────────────────
tracker.get_upstream("silver.orders").show()
tracker.get_downstream("bronze.orders_raw").show()
tracker.get_job_runs("daily_orders_etl", last_n=10).show()
```

---

## 11. Job Checkpointing

```python
from de_utils import JobCheckpoint

cp = JobCheckpoint(spark, state_table="gold._job_state", job_name="orders_incremental")

# ── Watermark management ──────────────────────────────────────────────────────
last_wm = cp.get_watermark("updated_at")      # None on first run
df = spark.table("bronze.orders").filter(
    f"updated_at > '{last_wm or '1970-01-01'}'"
)

# Process data ...

new_wm = df.agg({"updated_at": "max"}).collect()[0][0]
cp.set_watermark("updated_at", str(new_wm))
cp.commit()    # atomically write all pending state

# ── Idempotent partition detection ────────────────────────────────────────────
partition = "2024-06-01"
if cp.is_already_run(partition):
    print(f"Partition {partition} already processed — skipping")
else:
    process(partition)
    cp.mark_partition_done(partition)

# ── Arbitrary key-value state ─────────────────────────────────────────────────
cp.set("last_row_count", "50000")
count = cp.get("last_row_count")

# ── Inspect state ─────────────────────────────────────────────────────────────
cp.get_all_state().show()
cp.clear_state()    # reset job (e.g. for full reload)
```

---

## 12. Delta Lake Utilities

```python
from de_utils import DeltaUtils

du = DeltaUtils(spark)

# ── Maintenance ───────────────────────────────────────────────────────────────
du.optimize("silver.orders")
du.optimize("silver.orders", zorder_by=["customer_id", "order_date"])
du.vacuum("silver.orders", retention_hours=168)   # 7 days

# ── History & time travel ─────────────────────────────────────────────────────
du.show_history("silver.orders").show()
v5_df     = du.read_version("silver.orders", version=5)
ts_df     = du.read_timestamp("silver.orders", timestamp="2024-06-01 00:00:00")
du.restore("silver.orders", version=5)

# ── Clone ─────────────────────────────────────────────────────────────────────
du.clone("silver.orders", "gold.orders_backup", shallow=True)   # zero-copy
du.clone("silver.orders", "gold.orders_backup", shallow=False)  # deep copy

# ── Change data feed ──────────────────────────────────────────────────────────
changes_df = du.read_changes("silver.orders", start_version=10, end_version=20)

# ── Table info ────────────────────────────────────────────────────────────────
du.detail("silver.orders").show()
du.is_delta_table("silver.orders")        # True / False
du.convert_to_delta("silver.old_parquet") # convert Parquet → Delta in place
```

---

## 13. Audit Log

```python
from de_utils import AuditLog

audit = AuditLog(spark, audit_table="gold._audit_log", job_name="daily_etl")

# ── Manual entry ──────────────────────────────────────────────────────────────
audit.log(
    table="silver.orders",
    operation="FULL_LOAD",
    rows_inserted=50000,
    status="SUCCESS",
)

# ── Context manager (auto-captures timing + errors) ───────────────────────────
with audit.capture("silver.orders", "MERGE") as entry:
    ops.merge("silver.orders", updates_df, match_keys=["order_id"])
    entry.rows_updated  = 1200
    entry.rows_inserted = 300

# Any exception inside the context manager is caught, logged as FAILED,
# then re-raised — so your pipeline still fails fast.

# ── Flush buffered entries to the audit table ─────────────────────────────────
audit.flush()

# ── Query helpers ─────────────────────────────────────────────────────────────
audit.get_table_history("silver.orders").show()
audit.get_failed_jobs(since="2024-01-01").show()
audit.get_run_summary(run_id="abc-123").show()
```

Audit log schema:

| Column | Description |
|---|---|
| `run_id` | UUID per job invocation |
| `job_name` | Passed to `AuditLog(job_name=...)` |
| `table_name` | Target table |
| `operation` | FULL_LOAD / MERGE / SCD2 / DQ_CHECK / etc. |
| `rows_inserted` | Count of inserted rows |
| `rows_updated` | Count of updated rows |
| `rows_deleted` | Count of deleted rows |
| `status` | SUCCESS / FAILED / SKIPPED |
| `error_message` | Exception message if status=FAILED |
| `started_at` | Operation start timestamp |
| `ended_at` | Operation end timestamp |
| `duration_seconds` | Elapsed time |

---

## 14. Medallion Architecture

```python
from de_utils import BronzeLoader, SilverLoader, GoldLoader

# ── Bronze: land raw data as-is ───────────────────────────────────────────────
bronze = BronzeLoader(spark, adls_config=adls_cfg, database="bronze")
bronze.ingest(
    source_df=raw_df,
    target_table="orders_raw",
    source_tag="abfss://landing@acct.dfs.core.windows.net/orders/2024/06/",
)
# Automatically adds: _ingest_ts, _source_file, _run_id, _batch_date

# ── Silver: cleanse, deduplicate, enforce schema ───────────────────────────────
silver = SilverLoader(spark, database="silver")
silver.load(
    source_df=bronze_df,
    target_table="orders",
    key_columns=["order_id"],
    partition_keys=["year", "month"],
    not_null_columns=["order_id", "customer_id"],
    cast_map={"amount": "double", "order_date": "date"},
    dedup=True,
    target_schema=orders_schema,   # optional schema enforcement
)

# ── Gold: SCD2 dimensions or aggregated facts ─────────────────────────────────
gold = GoldLoader(spark, database="gold")

# Dimension table with full SCD2 history
gold.load_dimension(
    source_df=silver_df,
    target_table="dim_orders",
    key_columns=["order_id"],
    tracked_columns=["status", "amount"],
)

# Fact / aggregate table with built-in DQ checks
gold.load_fact(
    source_df=silver_df,
    target_table="fact_daily_orders",
    partition_keys=["year", "month", "day"],
    dq_rules=[
        Rule.not_null("order_id"),
        Rule.min_value("amount", 0),
        Rule.row_count(">=", 1),
    ],
)
```

---

## 15. Great Expectations Integration

```python
from de_utils import ExpectationSuiteBuilder, ValidatingLoader, LoadType

builder = ExpectationSuiteBuilder(spark, suite_name="orders_suite")

# ── Auto-generate a suite from a schema ───────────────────────────────────────
suite = builder.from_schema(
    schema=orders_schema,
    not_null_keys=["order_id", "customer_id"],
    unique_keys=["order_id"],
    numeric_ranges={"amount": (0, 1_000_000)},
    allowed_values={"status": ["PENDING","SHIPPED","DELIVERED","CANCELLED"]},
)

# ── Validate a DataFrame against the suite ────────────────────────────────────
result = builder.validate(df, suite)
builder.assert_passed(result)    # raises if any expectation fails

# ── Wire validation into DataLoader ──────────────────────────────────────────
vloader = ValidatingLoader(spark, database="silver", suite=suite)
vloader.load(df, "orders", load_type=LoadType.PARTITION, partition_keys=["year","month"])
# Validates BEFORE writing — aborts if validation fails

# ── Save / load suites ────────────────────────────────────────────────────────
builder.save_suite(suite, path="abfss://meta@acct.dfs.core.windows.net/suites/")
suite = builder.load_suite(path="abfss://meta@acct.dfs.core.windows.net/suites/orders_suite.json")
```

> **Note:** If `great_expectations` is not installed, `ExpectationSuiteBuilder` automatically falls back to `de_utils.quality` so your pipeline continues to work.

---

## End-to-End Example

A complete Bronze → Silver → Gold pipeline with quality checks, lineage, checkpointing, and audit logging:

```python
from de_utils import (
    ConfigLoader, ADLSConnector,
    BronzeLoader, SilverLoader, GoldLoader,
    DataQualityChecker, Rule,
    LineageTracker, JobCheckpoint, AuditLog,
    HistoryTable,
)

# ── Bootstrap ─────────────────────────────────────────────────────────────────
spark    = ConfigLoader.from_yaml("pipeline.yml").build_session()
adls_cfg = ConfigLoader.adls_from_yaml("pipeline.yml")
conn     = ADLSConnector(adls_cfg, spark)

audit   = AuditLog(spark,    audit_table="gold._audit_log",  job_name="daily_orders")
tracker = LineageTracker(spark, lineage_table="gold._lineage", job_name="daily_orders")
cp      = JobCheckpoint(spark, state_table="gold._job_state", job_name="daily_orders")

# ── Bronze: ingest raw ────────────────────────────────────────────────────────
with audit.capture("bronze.orders_raw", "INGEST") as entry:
    raw_df = conn.read_parquet("landing/orders/2024/06/")
    BronzeLoader(spark, adls_cfg, database="bronze").ingest(
        raw_df, "orders_raw", source_tag="landing/orders/2024/06/"
    )
    entry.rows_inserted = raw_df.count()

# ── Silver: cleanse + DQ ──────────────────────────────────────────────────────
last_wm = cp.get_watermark("updated_at")

with audit.capture("silver.orders", "INCREMENTAL"), \
     tracker.track("bronze.orders_raw", "silver.orders"):
    bronze_df = spark.table("bronze.orders_raw") \
        .filter(f"updated_at > '{last_wm or '1970-01-01'}'")

    qc = DataQualityChecker(spark, table_name="silver.orders")
    qc.add_rule(Rule.not_null("order_id"))
    qc.add_rule(Rule.unique(["order_id"]))
    qc.add_rule(Rule.min_value("amount", 0))
    qc.run(bronze_df).assert_no_failures()

    SilverLoader(spark, database="silver").load(
        bronze_df, "orders",
        key_columns=["order_id"],
        partition_keys=["year", "month"],
        cast_map={"amount": "double"},
        dedup=True,
    )

    new_wm = bronze_df.agg({"updated_at": "max"}).collect()[0][0]
    cp.set_watermark("updated_at", str(new_wm))
    cp.commit()

# ── Gold: SCD2 dimension + history ───────────────────────────────────────────
with audit.capture("gold.dim_orders", "SCD2"), \
     tracker.track("silver.orders", "gold.dim_orders"):
    silver_df = spark.table("silver.orders")
    GoldLoader(spark, database="gold").load_dimension(
        silver_df, "dim_orders",
        key_columns=["order_id"],
        tracked_columns=["status", "amount"],
    )
    HistoryTable(spark, database="gold").capture(
        silver_df, "orders", key_columns=["order_id"]
    )

audit.flush()
tracker.save()
print("Pipeline complete ✅")
```

